# Copy to `.env` and fill in locally. Do not commit `.env`.

# CollegeFootballData API — college player season stats for the draft pipeline
# https://collegefootballdata.com/key
CFBD_API_KEY=

# Optional alias
# GRIDIRONIQ_CFBD_API_KEY=

# Folder containing real draft board CSV/JSON files (consensus + variance); never commit proprietary boards
# GRIDIRONIQ_DRAFT_CONSENSUS_DIR=
